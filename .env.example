# Discord - your user token (NOT bot token)
# Find it: Open Discord in browser → F12 → Network tab → click any channel → Headers → Authorization
DISCORD_USER_TOKEN=your_token_here

# Channel ID - right click channel name → Copy Channel ID (requires Developer Mode in Settings → Advanced)
DISCORD_CHANNEL_ID=your_channel_id_here

# Groq API Key - free at console.groq.com → API Keys → Create API Key
GROQ_API_KEY=your_groq_key_here

# Telegram Bot Token - create bot via @BotFather on Telegram, then /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Number of messages to fetch per cycle (50-100)
MESSAGES_LIMIT=50

# LLM models (change if rate-limited)
LLM_MODEL=llama-3.3-70b-versatile
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Personal run delay between tickers (seconds, to avoid Groq rate limits)
PERSONAL_DELAY_SECONDS=8
